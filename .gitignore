# ==============================================================
# OPTIM AI BRE Engine — .gitignore
# ==============================================================

# ---- .NET build artifacts ----
**/bin/
**/obj/
*.user
*.suo
.vs/
*.DotSettings.user
TestResults/

# ---- Node.js ----
node_modules/
.next/
out/
.cache/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ---- Environment & Secrets ----
.env
.env.local
.env.production
.env.production.local
!.env.example
docker/.env
!docker/.env.example

# ---- Logs ----
logs/
*.log

# ---- Docker SSL certs ----
docker/ssl/

# ---- Database backups ----
backups/

# ---- OS files ----
.DS_Store
Thumbs.db
desktop.ini

# ---- IDE ----
.vscode/
.idea/
*.swp
*.swo

# ---- Rider ----
.idea/
*.sln.iml
