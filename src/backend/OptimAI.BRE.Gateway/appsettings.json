  "AiOptions": {
    "Endpoint": "",
    "ApiKey": "",
    "ModelName": "gpt-4o",
    "UseAzureOpenAI": true
  },
  "AllowedOrigins": [
    "http://localhost:3000",
    "https://localhost:3000"
  ],
  "Serilog": {
