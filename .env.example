# ==============================================================
# OPTIM AI BRE Engine — Environment Variables Reference
#
# FOR LOCAL DEVELOPMENT:
#   cp .env.example .env
#   Edit .env with your local values
#   Use docker compose up -d (reads from docker/.env.example)
#
# FOR RENDER DEPLOYMENT:
#   All variables are configured automatically via render.yaml.
#   Sensitive values (JWT_SECRET, DB passwords) are auto-generated.
#   You only need to set AI keys if you want AI features.
# ==============================================================

# ==============================================================
# DATABASE
# Render injects DATABASE_URL automatically.
# Local dev uses the values in docker/.env.example.
# ==============================================================
DATABASE_URL=postgres://optimai:dev_password@localhost:5432/optimai_bre

# ==============================================================
# REDIS
# Render injects REDIS_URL automatically.
# Local dev uses the Redis container in docker-compose.yml.
# ==============================================================
REDIS_URL=redis://:dev_redis_password@localhost:6379

# ==============================================================
# JWT SECRET
# Render auto-generates this (generateValue: true in render.yaml).
# For local dev, use any string >= 32 characters.
# ==============================================================
Jwt__SecretKey=LOCAL_DEV_SECRET_KEY_MINIMUM_32_CHARACTERS_LONG
Jwt__Issuer=OptimAI.BRE
Jwt__Audience=OptimAI.BRE.Clients
Jwt__AccessTokenExpiryMinutes=480
Jwt__RefreshTokenExpiryDays=30

# ==============================================================
# AI SERVICE — Optional
# Leave blank to run without AI features.
#
# Option A (OpenAI):  USE_AZURE=false, set ApiKey to sk-...
# Option B (Azure):   USE_AZURE=true, set Endpoint + ApiKey
# ==============================================================
AiOptions__UseAzureOpenAI=false
AiOptions__ApiKey=
AiOptions__Endpoint=
AiOptions__ModelName=gpt-4o

# ==============================================================
# CORS — Frontend URL
# On Render this is auto-set to the frontend service URL.
# For local dev, use http://localhost:3000.
# ==============================================================
AllowedOrigins__0=http://localhost:3000
AllowedOrigins__1=https://localhost:3000

# ==============================================================
# FRONTEND — API URL (baked at build time in Next.js)
# On Render: https://optim-ai-bre-api.onrender.com/api/v1
# Local Docker: /api/v1  (nginx proxies to backend)
# Local bare: http://localhost:5000/api/v1
# ==============================================================
NEXT_PUBLIC_API_URL=http://localhost:5000/api/v1

# ==============================================================
# RUNTIME
# ==============================================================
ASPNETCORE_ENVIRONMENT=Development
NODE_ENV=development
PORT=8080
